PORT=5001
OPENAI_API_KEY=your_project_service_account_key_here
OPENAI_MODEL=gpt-5.2

# Shared app gate for internal team access. Leave blank only for local development.
APP_ACCESS_TOKEN=replace_with_a_team_access_code

# Comma-separated exact origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Request guardrails
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
MAX_NARRATIVE_CHARS=6000
OPENAI_TIMEOUT_MS=20000

# Optional dynamic SEO enrichment from Semrush. Leave blank to use local keyword heuristics only.
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
SEMRUSH_RESULTS_PER_SEED=8
SEMRUSH_EXPORT_LIMIT=25
SEMRUSH_TIMEOUT_MS=8000
SEO_CACHE_TTL_MS=21600000
SEMRUSH_SNAPSHOT_PATH=./data/semrush-keywords.json
SEO_SNAPSHOT_SEEDS=
SEO_SNAPSHOT_SEEDS_FILE=./data/keyword-seeds.json

# Optional practice-specific keyword hints. These are blended with the Semrush-informed defaults.
SEO_KEYWORDS=therapy,counseling,online therapy
